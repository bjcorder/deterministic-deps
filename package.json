{
  "name": "deterministic-deps",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to enforce deterministic dependency declarations across ecosystems.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "bundle": "ncc build src/main.ts --license licenses.txt --source-map --out dist && node scripts/trim-dist.js",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --coverage --runInBand",
    "audit": "npm audit --audit-level=high",
    "all": "npm run lint && npm run test && npm run build && npm run bundle"
  },
  "keywords": [
    "github-action",
    "dependencies",
    "supply-chain",
    "deterministic",
    "sha-pinning"
  ],
  "author": "Brian Corder",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "1.11.1",
    "glob": "13.0.6",
    "js-yaml": "4.1.1",
    "minimatch": "10.2.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vercel/ncc": "0.38.4",
    "ajv": "8.20.0",
    "eslint": "10.3.0",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
  },
  "packageManager": "npm@11.12.1",
  "overrides": {
    "undici": "7.25.0"
  },
  "engines": {
    "node": ">=24"
  }
}
