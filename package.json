{
  "name": "deterministic-deps",
  "version": "1.1.0",
  "private": true,
  "description": "GitHub Action to enforce deterministic dependency declarations across ecosystems.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "bundle": "ncc build src/main.ts --license licenses.txt --source-map --out dist && node scripts/trim-dist.js",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --coverage --runInBand",
    "audit": "npm audit --audit-level=high",
    "all": "npm run lint && npm run test && npm run build && npm run bundle"
  },
  "keywords": [
    "github-action",
    "dependencies",
    "supply-chain",
    "deterministic",
    "sha-pinning"
  ],
  "author": "Brian Corder",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "osl-actions-core": "github:Ozark-Security-Labs/osl-actions-core#23007f60ab3ee61aefe66202f4790b0c9e6552e4",
    "osl-glob": "github:Ozark-Security-Labs/osl-glob#3d32991b7f0fcdff9c394e3025b40a6a5e253b44",
    "osl-js-yaml": "github:Ozark-Security-Labs/osl-js-yaml#721957e87b8fd2716d29c30a859ac816b2768f0f",
    "osl-minimatch": "github:Ozark-Security-Labs/osl-minimatch#4a0ff5b8e7ab0a3d12c5ef09660994125f759e3b"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.4",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vercel/ncc": "0.38.4",
    "ajv": "8.20.0",
    "eslint": "10.4.0",
    "jest": "30.4.2",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
  },
  "packageManager": "npm@11.12.1",
  "overrides": {
    "undici": "7.25.0"
  },
  "engines": {
    "node": ">=24"
  }
}
