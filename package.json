{
  "name": "deterministic-deps",
  "version": "1.1.0",
  "private": true,
  "description": "GitHub Action to enforce deterministic dependency declarations across ecosystems.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "bundle": "ncc build src/main.ts --license licenses.txt --source-map --out dist && node scripts/trim-dist.js",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "jest --coverage --runInBand",
    "audit": "npm audit --audit-level=high",
    "all": "npm run lint && npm run test && npm run build && npm run bundle"
  },
  "keywords": [
    "github-action",
    "dependencies",
    "supply-chain",
    "deterministic",
    "sha-pinning"
  ],
  "author": "Brian Corder",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "osl-actions-core": "github:Ozark-Security-Labs/osl-actions-core#d0839bc290bd7f6c04710485f65600896fce9086",
    "osl-glob": "github:Ozark-Security-Labs/osl-glob#b1bf03dd93c31cb2cd0211419113ed0cd5873cb3",
    "osl-js-yaml": "github:Ozark-Security-Labs/osl-js-yaml#b04ff4fdceada2baf698fd7d374b0ca44fa469b5",
    "osl-minimatch": "github:Ozark-Security-Labs/osl-minimatch#6e498460536f6296c405df7190365ae164fedace"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vercel/ncc": "0.38.4",
    "ajv": "8.20.0",
    "eslint": "10.3.0",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24"
  }
}
