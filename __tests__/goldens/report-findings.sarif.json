{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "deterministic-deps",
          "informationUri": "https://github.com/bjcorder/deterministic-deps",
          "rules": [
            {
              "id": "github-actions/sha-pin",
              "shortDescription": {
                "text": "github-actions/sha-pin"
              }
            },
            {
              "id": "containers/image-digest",
              "shortDescription": {
                "text": "containers/image-digest"
              }
            },
            {
              "id": "rust/git-rev-sha",
              "shortDescription": {
                "text": "rust/git-rev-sha"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "github-actions/sha-pin",
          "level": "error",
          "message": {
            "text": "Action 'actions/checkout@v4' is pinned to 'v4', not a full commit SHA. Replace branch, tag, or short SHA refs with a full 40-character commit SHA."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".github/workflows/ci.yml"
                },
                "region": {
                  "startLine": 7
                }
              }
            }
          ],
          "properties": {
            "ecosystem": "github-actions",
            "severity": "high"
          }
        },
        {
          "ruleId": "containers/image-digest",
          "level": "warning",
          "message": {
            "text": "Container image 'node:20' is not pinned by digest. Use an immutable image reference such as name:tag@sha256:<digest>."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "Dockerfile"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "properties": {
            "ecosystem": "containers",
            "severity": "medium"
          }
        },
        {
          "ruleId": "rust/git-rev-sha",
          "level": "error",
          "message": {
            "text": "Rust git dependency 'demo = { git = \"https://github.com/acme/demo.git?rev=0123456789abcdef0123456789abcdef01234567\" }' does not pin a rev commit SHA. Add rev = \"<40-character commit SHA>\" to git dependencies."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "Cargo.toml"
                },
                "region": {
                  "startLine": 2
                }
              }
            }
          ],
          "properties": {
            "ecosystem": "rust",
            "severity": "high"
          },
          "fixes": [
            {
              "description": {
                "text": "Add explicit Cargo rev '0123456789abcdef0123456789abcdef01234567' from the existing git URL."
              },
              "artifactChanges": [
                {
                  "artifactLocation": {
                    "uri": "Cargo.toml"
                  },
                  "replacements": [
                    {
                      "deletedRegion": {
                        "startLine": 2,
                        "endLine": 2
                      },
                      "insertedContent": {
                        "text": "demo = { git = \"https://github.com/acme/demo.git?rev=0123456789abcdef0123456789abcdef01234567\", rev = \"0123456789abcdef0123456789abcdef01234567\" }\n"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
